# Named .env.production (not .env.prod) because Vite reads this filename by default for production builds

# Stack Auth - Yapit project (client key is public, safe to commit)
VITE_STACK_BASE_URL=https://auth.yapit.md
VITE_STACK_AUTH_PROJECT_ID=6038930b-72c1-407f-9e38-f1287a4d1ede
VITE_STACK_AUTH_CLIENT_KEY=pck_m04c3bgjsmstpk4khbhtma5161b694zcrk94v6dcavpbr

# Relative URL - nginx proxies /api/* to gateway
VITE_API_BASE_URL=/api

# WebSocket URL - needs full URL for production
VITE_WS_BASE_URL=wss://yapit.md/api

# Error monitoring (DSN is public, safe to commit — only allows event submission)
