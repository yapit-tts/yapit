# Yapit Self-Hosting Configuration
# Copy this file to .env.selfhost and customize as needed.
# The app works out of the box with `make self-host`, but AI extraction and custom TTS models need to be configured.
# You may also want to increase the audio-cache size depending on your experience, if your disk space allows it.

# ============================================================================
# AI document extraction (vision-based PDF/image processing)
# ============================================================================

# Option 1: Google Gemini
# AI_PROCESSOR=gemini
# GOOGLE_API_KEY=your-key-here
#
# Option 2: Any OpenAI-compatible endpoint (vLLM, Ollama, LiteLLM, OpenRouter, etc.)
# AI_PROCESSOR=openai
# AI_PROCESSOR_BASE_URL=https://openrouter.ai/api/v1
# AI_PROCESSOR_API_KEY=your-key
# AI_PROCESSOR_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# ============================================================================
# TTS - Optional models beyond kokoro cpu/gpu
# ============================================================================

# Option 1: OpenAI-compatible TTS — use any server implementing /v1/audio/speech
# Works with: vLLM-Omni (Qwen3-TTS), Kokoro-FastAPI, AllTalk, openedai-speech, etc.
# OPENAI_TTS_BASE_URL=http://localhost:8880/v1
# OPENAI_TTS_API_KEY=your-key-or-empty
# OPENAI_TTS_MODEL=kokoro
# OPENAI_TTS_VOICES=alloy,echo,fable,nova,onyx,shimmer  # optional, auto-discovered if server supports GET /v1/audio/voices
# Option 2: Inworld TTS API | https://inworld.ai
# INWORLD_API_KEY=your-key-here

# ============================================================================
# Kokoro (TTS) and Yolo (Image extraction for AI-transform) CPU worker settings
# ============================================================================

# You can set the replica count to zero if you use GPU workers (see README)
KOKORO_CPU_REPLICAS=1  # for a single user on 1-2x speed, 1-2 kokoro replicas should be sufficient for real-time, depending on your cpu
YOLO_CPU_REPLICAS=1 # increase to speed up image extraction on large documents
OMP_NUM_THREADS=4 # for kokoro + yolo | up to ~8 can improve time to first audio, with diminishing returns

# ============================================================================
# CACHES (stored in Docker volumes, persist across restarts, LRU eviction)
# ============================================================================

AUDIO_CACHE_TYPE=sqlite
AUDIO_CACHE_CONFIG__PATH=/data/audio_cache
AUDIO_CACHE_CONFIG__MAX_SIZE_MB=1024 # increase to cache more audio

DOCUMENT_CACHE_TYPE=sqlite
DOCUMENT_CACHE_CONFIG__PATH=/data/document_cache
DOCUMENT_CACHE_CONFIG__MAX_SIZE_MB=1024 # no point in increasing - caches document fetches / uploads 

EXTRACTION_CACHE_TYPE=sqlite
EXTRACTION_CACHE_CONFIG__PATH=/data/extraction_cache
EXTRACTION_CACHE_CONFIG__MAX_SIZE_MB=1024 # increase to cache extraction results for longer

DOCUMENT_MAX_DOWNLOAD_SIZE=104857600 # restricts upload filesize

# ============================================================================
# Text-chunking algorithm
# ============================================================================

MAX_BLOCK_CHARS=250 # No block is larger than this value times the soft limit
SOFT_LIMIT_MULT=1.3 # Helps make block splits more natural
MIN_CHUNK_SIZE=40 # Helps make block splits more natural

# ============================================================================
# AUTH + BILLING (disabled for single-user selfhost)
# ============================================================================

AUTH_ENABLED=false
BILLING_ENABLED=false

# To enable multi-user auth: set AUTH_ENABLED=true, uncomment the section below,
# and run `make self-host-auth` instead of `make self-host`.
#
# STACK_AUTH_API_HOST=http://stack-auth:8102
# STACK_AUTH_APP_HOST=http://stack-auth:5173
# STACK_AUTH_PROJECT_ID=a12651bb-7824-459d-b424-21a0950ab902
# STACK_AUTH_SERVER_KEY=ssk_0fqsegjvkkas2yr4eb78z58wr3v5r3z7hv11qtv4n2qsr
# STACK_AUTH_CLIENT_KEY=pck_8ny111ccr9yyhty8vrmjk5ab32ezvcf19crck312j42p0
#
# NEXT_PUBLIC_STACK_API_URL=http://localhost:8102
# NEXT_PUBLIC_STACK_DASHBOARD_URL=http://localhost:8101
# STACK_DATABASE_CONNECTION_STRING=postgres://yapit:yapit@postgres:5432/yapit
# STACK_CLICKHOUSE_URL=http://clickhouse:8123
# STACK_CLICKHOUSE_ADMIN_PASSWORD=clickhouse-selfhost
# STACK_CLICKHOUSE_EXTERNAL_PASSWORD=clickhouse-selfhost
# STACK_SERVER_SECRET=change-me-generate-with-openssl-rand-base64-32
# STACK_SEED_INTERNAL_PROJECT_ALLOW_LOCALHOST=true
# STACK_SEED_INTERNAL_PROJECT_SIGN_UP_ENABLED=true
# STACK_SKIP_SEED_SCRIPT=false
# ANONYMOUS_SESSION_SECRET=change-me-to-a-random-string

# ============================================================================
# DATABASE
# ============================================================================

# Data persists across restarts. Schema is managed by Alembic migrations.
DB_DROP_AND_RECREATE=0
DB_SEED=1
SQLALCHEMY_ECHO=0

DATABASE_URL=postgresql+asyncpg://yapit:yapit@postgres:5432/yapit
POSTGRES_USER=yapit
POSTGRES_PASSWORD=yapit
POSTGRES_DB=yapit

# ============================================================================
# REDIS
# ============================================================================

REDIS_URL=redis://redis:6379/0
DEFUDDLE_SERVICE_URL=http://defuddle:8001

# ============================================================================
# CORS
# ============================================================================

# Frontend origin. Change if you serve on a different port.
CORS_ORIGINS='["http://localhost"]'

# ============================================================================
# IMAGE STORAGE
# ============================================================================

IMAGE_STORAGE_TYPE=local # local (filesystem, served by gateway) | r2 (requires Cloudflare R2 setup)
IMAGES_DIR=/data/images

# ============================================================================
# METRICS (optional — powers the dashboard via `make dashboard`)
# ============================================================================

# METRICS_DATABASE_URL=postgresql://metrics:metrics@metrics-db:5432/metrics
LOG_DIR=/data/gateway/logs

ANONYMOUS_SESSION_SECRET=selfhost-not-used
